{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-openagent/dev/assets/oh-my-opencode.schema.json",
  "sisyphus_agent": {
    "preserve_native_agents": true,
    "default_builder_enabled": false,
    "planner_enabled": false,
    "replace_plan": false,
    "hephaestus_enabled": false,
    "atlas_enabled": false,
    "junior_enabled": false
  },
  "disabled_commands": [
    "init-deep",
    "refactor",
    "remove-ai-slops",
    "hyperplan"
  ],
  "agents": {
    "sisyphus": {
      "prompt_append": "file://./oh-my-openagent/prompts/sisyphus-lightweight.txt"
    }
  }
}
